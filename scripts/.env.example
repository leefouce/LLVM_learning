# 复制本文件为 scripts/.env 并填好真实值。
# scripts/.env 已被 .gitignore 忽略，不会进入 git，凭据安全。

# === VM 连接 ===
VM_HOST=192.168.x.x        # 虚拟机 IP 或主机名
VM_USER=youruser           # 登录用户名
VM_PORT=22                 # SSH 端口（默认 22）

# 认证方式：推荐用密钥。填密钥文件的绝对路径；留空则用 ssh 默认行为（可能提示输密码）。
SSH_KEY=                   # 例：/Users/leefouce/.ssh/id_ed25519

# === VM 上的项目目录 ===
# 本仓库会 rsync 同步到这里（绝对路径，脚本会自动创建）。
VM_DIR=/home/youruser/llvm_learning

# === 可选：VM 上 LLVM 的 bin 目录 ===
# 若 LLVM 不在默认 PATH（比如自编译装在某目录），填这里，会加进 PATH。
# 留空则直接用 VM 登录后的 PATH。
LLVM_BIN=

# === 可选：VM 上 alive-tv 所在目录（Alive2 build）===
# 第 7 章验证用；版本需与 LLVM_BIN 一致。
ALIVE2_BIN=
